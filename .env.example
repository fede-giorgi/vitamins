# LangChain API Keys Configuration
# Copy this file to '.env' and fill in your keys

# Provider configuration: "ollama", "openai", "gemini"
# You can also change LLM_PROVIDER directly in scripts/1_prepare_data.py
# LLM_PROVIDER=ollama

# OpenAI API Key (required if LLM_PROVIDER is 'openai')
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Key (required if LLM_PROVIDER is 'gemini')
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: LangSmith Tracing for debugging LangChain calls
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langchain_api_key_here
# LANGCHAIN_PROJECT=neiss-vitamins
